# ───────────────────────── FitLens Workforce Supply Intelligence ─────────────────────────
# Copy to .env and fill in. Every integration below is OPTIONAL: a connector with no
# credentials runs in clearly-labeled MOCK mode. Provide creds to activate the real client.

# ── Core ──
DATABASE_URL=sqlite:///./.fitlens.db          # prod: postgresql+psycopg://user:pass@host:5432/fitlens
ENVIRONMENT=development
API_PORT=8000
WEB_ORIGIN=http://localhost:3000

# ── Vector store (default: local ONNX cosine). Set provider to pinecone|weaviate to use a service ──
VECTOR_PROVIDER=local
PINECONE_API_KEY=
PINECONE_INDEX=fitlens
WEAVIATE_URL=
WEAVIATE_API_KEY=

# ── LLM providers (default: local deterministic fallback) ──
LLM_PROVIDER=local                            # local|openai|anthropic|gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── ATS / VMS integrations (🔴 require customer accounts) ──
JOBDIVA_CLIENT_ID=
JOBDIVA_USERNAME=
JOBDIVA_PASSWORD=
BULLHORN_CLIENT_ID=
BULLHORN_CLIENT_SECRET=
BULLHORN_USERNAME=
BULLHORN_PASSWORD=
CEIPAL_API_KEY=
CEIPAL_EMAIL=
CEIPAL_PASSWORD=

# ── Job boards (🔴 LinkedIn/Dice scraping is ToS-restricted; use official APIs/partner feeds) ──
DICE_API_KEY=
INDEED_PUBLISHER_ID=
MONSTER_API_KEY=
LINKEDIN_ACCESS_TOKEN=

# ── Communications ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# ── Auth (Azure AD / Okta) ──
AUTH_PROVIDER=dev                             # dev|azuread|okta
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
OKTA_DOMAIN=
OKTA_CLIENT_ID=
